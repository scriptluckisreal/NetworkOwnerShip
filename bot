-- Bounce System
RS.Heartbeat:Connect(function()
    local now = os.clock()
    for part, endTime in pairs(S.bouncyParts) do
        if now > endTime or not part or not part.Parent then S.bouncyParts[part] = nil end
    end
    for part in pairs(S.bouncyParts) do
        if part and part.Parent and not part.Anchored then
            local touching = part:GetTouchingParts()
            if #touching > 0 then
                local vel = part.AssemblyLinearVelocity
                if vel.Magnitude > 3 then
                    local other = touching[1]
                    local n = (part.Position - other.Position).Unit
                    if n.Magnitude < 0.01 then n = Vector3.new(0, 1, 0) end
                    local ref = vel - 2 * vel:Dot(n) * n
                    safePhysics(part, ref * 0.85)
                end
            end
        end
    end
    if S.bounceAuraActive and LP.Character then
        local hrp = LP.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            for _, p in pairs(WS:GetPartBoundsInRadius(hrp.Position, 25)) do
                if p:IsA("BasePart") and not p.Anchored then
                    local m = p:FindFirstAncestorOfClass("Model")
                    local isNPC = m and findHumanoid(m) and not PLRS:GetPlayerFromCharacter(m)
                    if isNPC or not m then S.bouncyParts[p] = now + 10 end
                end
            end
        end
    end

    -- TP Aura Logic
    if S.tpAuraActive then
        for _, part in pairs(WS:GetPartBoundsInRadius(S.savedPos.Position, 20)) do
            if not part.Anchored and part:IsA("BasePart") then
                local model = part:FindFirstAncestorOfClass("Model")
                if model then
                    local hum = findHumanoid(model)
                    if hum and PLRS:GetPlayerFromCharacter(model) then continue end -- Don't TP players
                end
                if waitForOwnership(part, 0.2) then
                    local jitter = Vector3.new(math.random(-2,2), 0, math.random(-2,2))
                    pivotTarget(part, S.savedPos + jitter)
                end
            end
        end
    end

