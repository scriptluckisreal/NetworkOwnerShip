				if findHumanoid(ins) then
					autoKillTracked[ins] = true
				end
			elseif ins:IsA("Humanoid") then
				task.defer(function()
					if not S.autoKillActive then return end
					local ancestor = ins.Parent
					while ancestor and ancestor ~= WS do
						if ancestor:IsA("Model") then
							if not PLRS:GetPlayerFromCharacter(ancestor) then
								autoKillTracked[ancestor] = true
							end
							break
