local function getMouseTarget()
	local cam = WS.CurrentCamera
	local ray = cam:ViewportPointToRay(MOUSE.X, MOUSE.Y)
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = {LP.Character}
	local lastOrigin = ray.Origin
	local maxDist = 500000; local traveled = 0; local iterations = 0
	while traveled < maxDist and iterations < 10 do
		iterations = iterations + 1
		local dist = maxDist - traveled
		local result = workspace:Raycast(lastOrigin, ray.Direction * dist, params)
		if not result then return nil end
		local part = result.Instance
		local continueRay = false
		if S.clickThruInvisible and part:IsA("BasePart") and part.Transparency > 0.5 then continueRay = true end
		if S.clickThruObstacles then
			local model = part:FindFirstAncestorOfClass("Model")
			local isNPC = isnpc(model)
			if not isNPC and part:IsA("BasePart") and part.Anchored then continueRay = true end
		end
		if continueRay then traveled = traveled + result.Distance; lastOrigin = result.Position + (ray.Direction * 0.1)
		else return part end
	end
	return nil
end

