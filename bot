				removeESP(model)
			end
		end
		for _, model in pairs(WS:GetDescendants()) do
			if model:IsA("Model") and not S.espHighlights[model] then addESP(model) end
		end
	end

	-- Wind + Tornado Logic
	local time = os.clock()
	if S.windChaosActive or S.windRealismActive then
		S.windTick = S.windTick + 1
		if S.windTick > 2 then
			S.windTick = 0
			local char = LP.Character
			if char then
				local root = char:FindFirstChild("HumanoidRootPart")
				if root then
					local parts = WS:GetPartBoundsInRadius(root.Position, S.windChaosActive and 150 or 100)
					for _, part in pairs(parts) do
						if part:IsA("BasePart") and not part.Anchored and not part:IsDescendantOf(char) then
							claimOwnership(part)
							if partowner(part) then
								local force = Vector3.new(0,0,0)
								if S.windRealismActive then
									local x = math.sin(time * 2 + part.Position.X * 0.1) * 10
									local z = math.cos(time * 2.5 + part.Position.Z * 0.1) * 10
									local y = math.sin(time + part.Position.Y * 0.1) * 5
									force = Vector3.new(x, y, z)
								else
									force = Vector3.new(math.random(-15,15), math.random(-5,10), math.random(-15,15))
								end
								pcall(function()
									part.AssemblyLinearVelocity = part.AssemblyLinearVelocity + force
									part.AssemblyAngularVelocity = Vector3.new(math.random(-10,10), math.random(-10,10), math.random(-10,10))
								end)
							end
						end
					end
				end
			end
		end
	end

	-- IMPROVED TORNADO
	if S.tornadoActive then
		S.tornadoTimer = S.tornadoTimer + 1
		if S.tornadoTimer > 1 then
			S.tornadoTimer = 0
			local char = LP.Character
			if char then
				local root = char:FindFirstChild("HumanoidRootPart")
				if root then
					local center = root.Position
					local parts = WS:GetPartBoundsInRadius(center, 80)
					for _, part in pairs(parts) do
						if part:IsA("BasePart") and not part.Anchored and not part:IsDescendantOf(char) then
							claimOwnership(part)
							if partowner(part) then
								local diff = part.Position - center
								local flatDiff = Vector3.new(diff.X, 0, diff.Z)
								local dist = math.max(flatDiff.Magnitude, 0.1)
								local height = diff.Y

								local tangent = dist > 0.01 and Vector3.new(-flatDiff.Z/dist, 0, flatDiff.X/dist) or Vector3.new(1,0,0)
								local inward = -flatDiff.Unit

								local spinSpeed   = math.clamp(120/dist, 20, 100)
								local liftForce   = math.clamp(160 - height, 40, 160)
								local pullStrength = math.clamp(50/dist, 10, 50)

								local mass = part:GetMass()
								local massScale = math.clamp(10/mass, 0.5, 1.5)

								pcall(function()
									part.AssemblyLinearVelocity = (tangent * spinSpeed * massScale * 1.5) +
									                               (inward * pullStrength * massScale) +
									                               (Vector3.new(0, liftForce * massScale, 0))
									part.AssemblyAngularVelocity = Vector3.new(
										math.random(-40,40),
										spinSpeed * 0.8,
										math.random(-40,40)
									)
								end)
								S.tornadoAffected[part] = true
							end
						end
					end
				end
			end
		end
	end

	-- TP Aura
	if S.tpAuraActive and S.savedPosSet then
		local char = LP.Character
		if char then
			local root = char:FindFirstChild("HumanoidRootPart")
			if root then
				local parts = WS:GetPartBoundsInRadius(root.Position, 25)
				for _, part in pairs(parts) do
					local model = findNPCModel(part)
					if not model then model = findAnyModel(part) end
					if model and model ~= WS and not PLRS:GetPlayerFromCharacter(model) and model ~= LP.Character then
						task.spawn(function()
							local targetRoot = getPrimaryPart(model) or part
							if not targetRoot or targetRoot.Anchored then return end
							setSimRadius(math.huge)
							pcall(function() targetRoot:SetNetworkOwner(LP) end)
							for _ = 1, 10 do task.wait(0.03); setSimRadius(math.huge); pcall(function() targetRoot:SetNetworkOwner(LP) end); if partowner(targetRoot) then break end end
							if not partowner(targetRoot) then return end
							for _, v in pairs(getTargetParts(model)) do pcall(function() if v and not v.Anchored then v.Anchored = false end end) end
							local jitter = Vector3.new(math.random(-3,3), 0, math.random(-3,3))
							local destCF = CFrame.new(S.savedPos.Position + jitter)
							pivotTarget(model, destCF)
							for _, v in pairs(getTargetParts(model)) do
								pcall(function() if v and v.Parent and not v.Anchored then v.AssemblyLinearVelocity = Vector3.zero; v.AssemblyAngularVelocity = Vector3.zero end end)
							end
						end)
					end
				end
			end
		end
	end

	-- Chaos Mode
	if S.chaosModeActive then
		local char = LP.Character
		if char then
			local root = char:FindFirstChild("HumanoidRootPart")
			if root then
				local parts = WS:GetPartBoundsInRadius(root.Position, 40)
				for _, part in pairs(parts) do
					if part:IsA("BasePart") and not part.Anchored and not part:IsDescendantOf(char) then
						claimOwnership(part)
						if partowner(part) then
							pcall(function()
								part.AssemblyLinearVelocity = Vector3.new(math.random(-80,80), math.random(20,100), math.random(-80,80))
								part.AssemblyAngularVelocity = Vector3.new(math.random(-30,30), math.random(-30,30), math.random(-30,30))
							end)
						end
					end
				end
			end
		end
	end
end)

