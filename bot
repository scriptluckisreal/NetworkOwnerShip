-- ================== UTILITY FUNCTIONS ==================
local function setSimRadius(v)
	if sethiddenproperty then pcall(sethiddenproperty, LP, "SimulationRadius", v)
	else pcall(function() LP.SimulationRadius = v end) end
end

local function partowner(part)
	local age = 1
	pcall(function() age = part.ReceiveAge end)
	return age == 0
end

local function claimOwnership(part)
	if not part or part.Anchored then return end
	setSimRadius(math.huge)
	pcall(function() part:SetNetworkOwner(LP) end)
end

local function safePhysics(part, vel, ang)
	if not part or not part.Parent or part.Anchored then return end
	claimOwnership(part)
	pcall(function()
		if vel then part.AssemblyLinearVelocity = vel end
		if ang then part.AssemblyAngularVelocity = ang end
	end)
end

local function findHumanoid(model)
	if not model then return nil end
	local h = model:FindFirstChildOfClass("Humanoid")
	if h then return h end
	for _, v in ipairs(model:GetDescendants()) do
		if v:IsA("Humanoid") then return v end
	end
	return nil
end

local function isnpc(ins)
	local hum = findHumanoid(ins)
	return hum and not PLRS:GetPlayerFromCharacter(ins) and ins or nil
end

local function findNPCModel(part)
	local cur = part and part.Parent
	while cur and cur ~= WS do
		if cur:IsA("Model") and cur:FindFirstChildOfClass("Humanoid") and not PLRS:GetPlayerFromCharacter(cur) then return cur end
		cur = cur.Parent
	end
	return nil
end

local function findAnyModel(part)
	local cur = part and part.Parent
	while cur and cur ~= WS do
		if cur:IsA("Model") then return cur end
		cur = cur.Parent
	end
	return part
end

local function setCollision(character, enabled)
	if not character then return end
	for _, v in pairs(character:GetDescendants()) do
		if v:IsA("BasePart") then pcall(function() v.CanCollide = enabled end) end
	end
end

local function zeroVelocity(character)
	if not character then return end
	for _, v in pairs(character:GetDescendants()) do
		if v:IsA("BasePart") then
			pcall(function()
				v.AssemblyLinearVelocity = Vector3.zero
				v.AssemblyAngularVelocity = Vector3.zero
			end)
		end
	end
end

local function getRootPart(model)
	if not model then return nil end
	if model:IsA("BasePart") then return model end
	local hrp = model:FindFirstChild("HumanoidRootPart")
	if hrp then return hrp end
	for _, v in ipairs(model:GetDescendants()) do
		if v.Name == "HumanoidRootPart" and v:IsA("BasePart") then return v end
	end
	local hum = findHumanoid(model)
	if hum and hum.RootPart then return hum.RootPart end
	for _, v in ipairs(model:GetDescendants()) do
		if v:IsA("BasePart") and not v.Anchored then return v end
	end
	return nil
end

local function getPrimaryPart(target)
	if not target then return nil end
	if target:IsA("Model") and target.PrimaryPart then return target.PrimaryPart end
	return getRootPart(target)
end

local function pivotTarget(target, cf)
	if not target then return end
	if target:IsA("Model") then pcall(function() target:PivotTo(cf) end)
	elseif target:IsA("BasePart") then pcall(function() target.CFrame = cf end) end
end

local function getTargetPivot(target)
	if not target then return CFrame.new() end
	if target:IsA("Model") then return target:GetPivot()
	elseif target:IsA("BasePart") then return target.CFrame end
	return CFrame.new()
end

local function getTargetParts(target)
	local parts = {}
	if target:IsA("Model") then
		for _, v in pairs(target:GetDescendants()) do if v:IsA("BasePart") then table.insert(parts, v) end end
	elseif target:IsA("BasePart") then table.insert(parts, target) end
	return parts
end

local function getActiveTarget() return S.currentnpc or S.currentpart end

local function getCameraSubject(model)
	-- UPDATED: Find "head" case-insensitively
	if not model then return nil end
	local hum = findHumanoid(model)
	if hum then return hum end

	-- Search for any part with "head" in the name (case-insensitive)
	for _, v in pairs(model:GetDescendants()) do
		if v:IsA("BasePart") and v.Name:lower():find("head") then
			return v
		end
	end

	return getRootPart(model)
end

local function deepUnanchor(model)
	if not model then return end
	for _, v in pairs(model:GetDescendants()) do
		if v:IsA("BasePart") then pcall(function() v.Anchored = false end) end
	end
end

local function deepDisableScripts(model)
	local disabled = {}
	if not model then return disabled end
	for _, v in pairs(model:GetDescendants()) do
		if (v:IsA("Script") or v:IsA("LocalScript")) and v.Enabled then
			pcall(function() v.Enabled = false; table.insert(disabled, v) end)
		end
	end
	return disabled
end

local function prepNPCHumanoid(model)
	local hum = findHumanoid(model)
	if not hum then return end
	pcall(function()
		hum.PlatformStand = false
		hum.AutoRotate = true
		if hum.WalkSpeed == 0 then hum.WalkSpeed = 16 end
		if hum.JumpPower == 0 then hum.JumpPower = 50 end
		hum:ChangeState(Enum.HumanoidStateType.Running)
	end)
end

local function updateBotLabel(btn)
	if not btn then return end
	if S.currentnpc then btn.Text = "NPC Selected: " .. S.currentnpc.Name
	elseif S.currentpart then btn.Text = (S.currentpart:IsA("Model") and "Model Selected: " or "Part Selected: ") .. S.currentpart.Name
	else btn.Text = "Bot Selected: None" end
end

local function serverFling(target)
	if not target or not target.Parent then return end
	if PLRS:GetPlayerFromCharacter(target) then return end
	local rootp = getPrimaryPart(target)
	if not rootp or rootp.Anchored then return end
	task.spawn(function()
		setSimRadius(math.huge)
		pcall(function() rootp:SetNetworkOwner(LP) end)
		for _ = 1, 8 do task.wait(); setSimRadius(math.huge); pcall(function() rootp:SetNetworkOwner(LP) end); if partowner(rootp) then break end end
		if partowner(rootp) then
			for _, v in pairs(getTargetParts(target)) do pcall(function() if not v.Anchored then v.Anchored = false end end) end
			pcall(function() rootp.AssemblyLinearVelocity = Vector3.new(math.random(-200,200), math.random(400,700), math.random(-200,200)) end)
		end
	end)
end

local function findBestSeat(target)
	if not target then return nil end
	for _, v in pairs(getTargetParts(target)) do if v:IsA("VehicleSeat") then return v end end
	for _, v in pairs(getTargetParts(target)) do if v:IsA("Seat") then return v end end
	return nil
end

local function disableTargetSeats(target)
	local disabled = {}
	if not target then return disabled end
	for _, p in pairs(getTargetParts(target)) do
		if (p:IsA("Seat") or p:IsA("VehicleSeat")) and not p.Disabled then
			pcall(function() p.Disabled = true; table.insert(disabled, p) end)
		end
	end
	return disabled
end

local function addESP(model)
	if not S.highlightsActive then return end
	if not model:FindFirstChildOfClass("Humanoid") or PLRS:GetPlayerFromCharacter(model) then return end
	local root = getRootPart(model); if not root or root.Anchored then return end
	if S.espHighlights[model] then return end
	local h = Instance.new("Highlight")
	h.FillTransparency = 0.6; h.OutlineTransparency = 0
	h.FillColor = Color3.fromRGB(255,50,50); h.OutlineColor = Color3.fromRGB(255,255,255)
	h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; h.Adornee = model; h.Parent = model
	S.espHighlights[model] = h
	model.AncestryChanged:Connect(function()
		if not model.Parent and S.espHighlights[model] then S.espHighlights[model]:Destroy(); S.espHighlights[model] = nil end
	end)
end

local function removeESP(model)
	if S.espHighlights[model] then S.espHighlights[model]:Destroy(); S.espHighlights[model] = nil end
end

local function updateUnanchoredHighlights()
	local char = LP.Character; local root = char and char:FindFirstChild("HumanoidRootPart")
	local searchParts = root and WS:GetPartBoundsInRadius(root.Position, 150) or WS:GetDescendants()
	local currentValid = {}
	for _, obj in pairs(searchParts) do
		local isPart = obj:IsA("BasePart"); local isModel = obj:IsA("Model")
		local target = isPart and obj or (isModel and getPrimaryPart(obj))
		if target and not target.Anchored and not target:IsDescendantOf(LP.Character) then
			if not S.unanchoredHighlights[target] then
				local h = Instance.new("Highlight")
				h.Name = "UnanchoredHighlight"; h.FillTransparency = 0.8; h.OutlineTransparency = 0
				h.FillColor = Color3.fromRGB(0,255,0); h.OutlineColor = Color3.fromRGB(100, 255, 100)
				h.Adornee = isPart and target or obj; h.Parent = isPart and target or obj
				S.unanchoredHighlights[target] = h
			end
			currentValid[target] = true
		end
	end
	for part, h in pairs(S.unanchoredHighlights) do
		if not currentValid[part] or not part.Parent or part.Anchored then
			if h then h:Destroy() end; S.unanchoredHighlights[part] = nil
		end
	end
end

local function isWheelPart(name)
	local n = name:lower()
	for _, kw in pairs(S.WHEEL_KEYWORDS) do if n == kw or n:find(kw) then return true end end
	return false
end

local function detectCarWheels(target, root)
	S.carWheelData = {}
	if not target or not root then return end
	for _, v in pairs(getTargetParts(target)) do
		if v == root or not isWheelPart(v.Name) or not partowner(v) then continue end
		local sz = v.Size; local dims = {sz.X, sz.Y, sz.Z}; table.sort(dims)
		table.insert(S.carWheelData, {part = v, radius = math.max((dims[2] + dims[3]) / 4, 0.3)})
	end
end

local function updateCarWheels(root, dt)
	if #S.carWheelData == 0 then return end
	local vel = root.AssemblyLinearVelocity
	local flatVel = Vector3.new(vel.X, 0, vel.Z)
	local speed = flatVel.Magnitude
	if speed < 0.1 then return end
	local axis = root.CFrame.RightVector
	for _, wd in pairs(S.carWheelData) do
		local wheel = wd.part
		if wheel and wheel.Parent then
			local angVel = speed / wd.radius
			pcall(function() wheel.AssemblyAngularVelocity = axis * angVel end)
		end
	end
end

-- ✅ IMPROVED: Stable driving physics with smoothing and safety clamps
local function applyCarPhysics(root)
	if not root or root.Anchored or not root.Parent then return end
	
	local vel = root.AssemblyLinearVelocity
	local flatVel = Vector3.new(vel.X, 0, vel.Z)
	local speed = flatVel.Magnitude
	local fwd = root.CFrame.LookVector
	local right = root.CFrame.RightVector
	
	-- Input handling with smoothing
	local targetAccel = 0
	if UIS:IsKeyDown(Enum.KeyCode.W) then targetAccel = S.CAR_ACCEL
	elseif UIS:IsKeyDown(Enum.KeyCode.S) then targetAccel = -S.CAR_BRAKE
	else targetAccel = -S.CAR_COAST end
	
	local currentSpeed = flatVel:Dot(fwd)
	local newSpeed = currentSpeed + targetAccel * S.CAR_SPEED
	
	-- HARD CLAMP to prevent flinging
	newSpeed = math.clamp(newSpeed, -S.CAR_SPEED * 0.5, S.CAR_SPEED)
	
	-- Smooth velocity transition with damping
	local dampingFactor = 0.88  -- Increased damping
	local targetXZ = fwd * newSpeed
	local newXZ = flatVel:Lerp(targetXZ, 0.15) * dampingFactor
	
	-- Steering with speed-based sensitivity + smoothing
	local targetTurn = 0
	local speedFactor = math.min(math.abs(newSpeed) / S.CAR_SPEED, 1)
	local steerDir = (newSpeed >= 0) and 1 or -1
	
	if UIS:IsKeyDown(Enum.KeyCode.A) then targetTurn = S.CAR_TURN * speedFactor * steerDir end
	if UIS:IsKeyDown(Enum.KeyCode.D) then targetTurn = -S.CAR_TURN * speedFactor * steerDir end
	
	S.carTurnCurrent = S.carTurnCurrent + (targetTurn - S.carTurnCurrent) * S.CAR_TURN_LERP
	
	-- SAFE physics application with clamps
	pcall(function()
		local newVel = Vector3.new(newXZ.X, vel.Y * 0.96, newXZ.Z)
		-- Prevent extreme velocities that cause flinging
		if newVel.Magnitude > S.CAR_SPEED * 1.2 then
			newVel = newVel.Unit * S.CAR_SPEED * 1.2
		end
		root.AssemblyLinearVelocity = newVel
		
		local newAngVel = Vector3.new(0, S.carTurnCurrent, 0)
		if math.abs(S.carTurnCurrent) > 10 then
			newAngVel = Vector3.new(0, math.clamp(S.carTurnCurrent, -8, 8), 0)
		end
		root.AssemblyAngularVelocity = newAngVel
	end)
end

