G["3"].MouseButton1Click:Connect(function()
    if S.controlActive then
        local sp = S.savedPosition; S.savedPosition = nil
        restorePlayer(sp, G["3"])
        return
    end
    if S.currentnpc then
        local capturedNPC = S.currentnpc
        setSimRadius(math.huge)
        local rootCheck = getRootPart(capturedNPC)
        if rootCheck then for _=1,5 do setSimRadius(math.huge); task.wait() end end
        local part = getRootPart(capturedNPC)
        if part and not part.Anchored then
            deepUnanchor(capturedNPC); S.disabledScripts = deepDisableScripts(capturedNPC)
            prepNPCHumanoid(capturedNPC)
            if LP and LP.Character then
                S.chr = LP.Character
                local chrhrp = S.chr:FindFirstChild("HumanoidRootPart")
                S.savedPosition = chrhrp and chrhrp.CFrame or nil
                setCollision(S.chr, false)
                local chrHum = S.chr:FindFirstChildOfClass("Humanoid")
                if chrHum then chrHum.PlatformStand = true end
                LP.Character = capturedNPC
                WS.CurrentCamera.CameraSubject = getCameraSubject(capturedNPC)
                S.npcMissingCount = 0
                S.deathcon = LP.CharacterAdded:Connect(function()
                    for _, v in pairs(S.disabledScripts) do pcall(function() v.Enabled = true end) end
                    S.disabledScripts = {}; S.savedPosition = nil
                    S.controlActive = false; G["3"].Text = "Control Bot"; restorePlayer(nil, G["3"])
                end)
                local move = 0.01; local npcRefreshTimer = 0
                S.cons = RS.PreSimulation:Connect(function()
                    if not S.controlActive then return end
                    setSimRadius(math.huge)
                    local currentChar = LP.Character
                    if currentChar ~= capturedNPC then
                        if capturedNPC and capturedNPC.Parent then
                            pcall(function() LP.Character = capturedNPC end)
                            pcall(function() WS.CurrentCamera.CameraSubject = getCameraSubject(capturedNPC) end)
                            currentChar = capturedNPC
                        end
                    end
                    if not currentChar then return end
                    local hum = findHumanoid(currentChar)
                    local root = hum and (hum.RootPart or getRootPart(currentChar))
                    if not hum or not root then return end
                    pcall(function() if hum.PlatformStand then hum.PlatformStand = false end end)
                    if not root.Anchored then pcall(function() root.CFrame = root.CFrame + Vector3.new(0, move, 0) end) end
                    move = -move; npcRefreshTimer = npcRefreshTimer + 1
                    if npcRefreshTimer >= 30 then
                        npcRefreshTimer = 0
                        pcall(function() deepUnanchor(currentChar) end)
                        pcall(function()
                            if hum.WalkSpeed == 0 then hum.WalkSpeed = 16 end
                            if hum.JumpPower == 0 then hum.JumpPower = 50 end
                            hum:ChangeState(Enum.HumanoidStateType.Running)
                        end)
                    end
                end)
                S.tpcon = RS.Heartbeat:Connect(function()
                    setSimRadius(math.huge)
