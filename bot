-- Orbit
local function collectOrbitTargets(center, excludeModel)
	local collected = {}; local seen = {}
	for _, part in pairs(WS:GetPartBoundsInRadius(center, S.ORBIT_RADIUS)) do
		if not part:IsA("BasePart") or part.Anchored then continue end
		local parentModel = part:FindFirstAncestorOfClass("Model")
		if parentModel then
			if PLRS:GetPlayerFromCharacter(parentModel) or parentModel == excludeModel or seen[parentModel] then continue end
			local mp = getPrimaryPart(parentModel)
			if mp and not mp.Anchored then
				seen[parentModel] = true
				local off = mp.Position - center
				local r = math.sqrt(off.X^2 + off.Z^2)
				table.insert(collected, {
					part = mp,
					angle = math.atan2(off.Z, off.X),
					radius = math.clamp(r < 4 and math.random(8,16) or r, 6, 40),
					speed = math.random(90,200) / 100,
					offsetY = math.random(-2,5)
				})
			end
		else
			if PLRS:GetPlayerFromCharacter(part) or seen[part] then continue end
			if excludeModel and part:IsDescendantOf(excludeModel) then continue end
			seen[part] = true
			local off = part.Position - center
			local r = math.sqrt(off.X^2 + off.Z^2)
			table.insert(collected, {
				part = part,
				angle = math.atan2(off.Z, off.X),
				radius = math.clamp(r < 4 and math.random(8,16) or r, 6, 40),
				speed = math.random(90,200) / 100,
				offsetY = math.random(-2,5)
			})
		end
	end
	return collected
end

