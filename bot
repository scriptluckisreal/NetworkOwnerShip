-- RING (ORBIT SELF)
local function buildRingNoCollisions()
    for _, nc in pairs(S.ringNoCollisions) do pcall(function() nc:Destroy() end) end
    S.ringNoCollisions = {}
    local char = LP.Character; if not char then return end
    local charParts = {}
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then table.insert(charParts, v) end
    end
    for _, od in pairs(S.orbitSelfObjects) do
        local p = od.part
        if p and p.Parent then
            for _, cp in pairs(charParts) do
                pcall(function()
                    local nc = Instance.new("NoCollisionConstraint")
                    nc.Part0 = p; nc.Part1 = cp; nc.Parent = char
                    table.insert(S.ringNoCollisions, nc)
                end)
            end
        end
    end
end

local function clearRingNoCollisions()
    for _, nc in pairs(S.ringNoCollisions) do pcall(function() nc:Destroy() end) end
    S.ringNoCollisions = {}
end

