-- ================== UTILITY FUNCTIONS ==================
local function setSimRadius(v)
    if sethiddenproperty then pcall(sethiddenproperty, LP, "SimulationRadius", v)
    else pcall(function() LP.SimulationRadius = v end) end
end

local function partowner(part)
    local age = 1; pcall(function() age = part.ReceiveAge end); return age == 0
end

local function waitForOwnership(part, timeout)
    if not part or part.Anchored then return false end
    setSimRadius(math.huge) -- Aggressively request ownership
    local start = os.clock()
    while (os.clock() - start) < timeout do
        if part:GetNetworkOwner() == LP then return true end
        local age = 1; pcall(function() age = part.ReceiveAge end)
        if age == 0 then return true end
        -- Small nudge to force physics engine to check ownership
        pcall(function() part.CFrame = part.CFrame + Vector3.new(0,0.001,0) end)
        task.wait(0.05)
    end
    return false
end

local function safePhysics(part, vel, ang)
    if not part or not part.Parent or part.Anchored then return end
    if waitForOwnership(part, 0.3) then
        pcall(function()
            if vel then part.AssemblyLinearVelocity = vel end
            if ang then part.AssemblyAngularVelocity = ang end
        end)
    end
end

local function findHumanoid(model)
    if not model then return nil end
    local h = model:FindFirstChildOfClass("Humanoid")
    if h then return h end
    for _, v in ipairs(model:GetDescendants()) do
        if v:IsA("Humanoid") then return v end
    end
    return nil
end

local function isnpc(ins)
    local hum = findHumanoid(ins)
    return hum and not PLRS:GetPlayerFromCharacter(ins) and ins or nil
end

local function findNPCModel(part)
    local cur = part and part.Parent
    while cur and cur ~= WS do
        if cur:IsA("Model") and cur:FindFirstChildOfClass("Humanoid") and not PLRS:GetPlayerFromCharacter(cur) then
            return cur
        end
        cur = cur.Parent
    end
    return nil
end

local function findAnyModel(part)
    local cur = part and part.Parent
    while cur and cur ~= WS do
        if cur:IsA("Model") then return cur end
        cur = cur.Parent
    end
    return part
end

local function setCollision(character, enabled)
    if not character then return end
    for _, v in pairs(character:GetDescendants()) do
        if v:IsA("BasePart") then pcall(function() v.CanCollide = enabled end) end
    end
end

local function zeroVelocity(character)
    if not character then return end
    for _, v in pairs(character:GetDescendants()) do
        if v:IsA("BasePart") then
            pcall(function()
                v.AssemblyLinearVelocity = Vector3.zero
                v.AssemblyAngularVelocity = Vector3.zero
            end)
        end
    end
end

local function getRootPart(model)
    if not model then return nil end
    if model:IsA("BasePart") then return model end
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp end
    for _, v in ipairs(model:GetDescendants()) do
        if v.Name == "HumanoidRootPart" and v:IsA("BasePart") then return v end
    end
    local hum = findHumanoid(model)
    if hum and hum.RootPart then return hum.RootPart end
    for _, v in ipairs(model:GetDescendants()) do
        if v:IsA("BasePart") and not v.Anchored then return v end
    end
    return nil
end

local function getPrimaryPart(target)
    if not target then return nil end
    if target:IsA("Model") and target.PrimaryPart then return target.PrimaryPart end
    return getRootPart(target)
end

local function pivotTarget(target, cf)
    if not target then return end
    if target:IsA("Model") then pcall(function() target:PivotTo(cf) end)
    elseif target:IsA("BasePart") then pcall(function() target.CFrame = cf end) end
end

local function getTargetPivot(target)
    if not target then return CFrame.new() end
    if target:IsA("Model") then return target:GetPivot()
    elseif target:IsA("BasePart") then return target.CFrame end
    return CFrame.new()
end

local function getTargetParts(target)
    local parts = {}
    if target:IsA("Model") then
        for _, v in pairs(target:GetDescendants()) do
            if v:IsA("BasePart") then table.insert(parts, v) end
        end
    elseif target:IsA("BasePart") then table.insert(parts, target) end
    return parts
end

local function getActiveTarget() return S.currentnpc or S.currentpart end

local function getCameraSubject(model)
