    -- wheel system
    local carWheelData = {}
    local WHEEL_KEYWORDS = {"wheel","tire","tyre","rim","hub","rubber","fl","fr","rl","rr","bl","br",
        "lf","rf","lr","frontleft","frontright","rearleft","rearright","backleft","backright",
        "leftfront","rightfront","leftrear","rightrear","leftback","rightback"}

    local function isWheelPart(name)
        local n = name:lower()
        for _, kw in pairs(WHEEL_KEYWORDS) do if n==kw or n:find(kw) then return true end end
    end

    local function detectCarWheels(target, root)
        carWheelData = {}
        if not target or not root then return end
        for _, v in pairs(getTargetParts(target)) do
            if v == root or not isWheelPart(v.Name) or not partowner(v) then continue end
            local restLocalCF  = root.CFrame:ToObjectSpace(v.CFrame)
            local restLocalRot = CFrame.fromMatrix(Vector3.zero,
                restLocalCF.RightVector, restLocalCF.UpVector, restLocalCF.LookVector)
            local carRight = Vector3.new(1,0,0)
            local dX=math.abs(restLocalCF.RightVector:Dot(carRight))
            local dY=math.abs(restLocalCF.UpVector:Dot(carRight))
            local dZ=math.abs(restLocalCF.LookVector:Dot(carRight))
            local axleAxis = (dX>=dY and dX>=dZ) and 0 or (dY>=dX and dY>=dZ) and 1 or 2
            local sz=v.Size; local dims={sz.X,sz.Y,sz.Z}; table.sort(dims)
            table.insert(carWheelData, {
                part=v, restLocalCF=restLocalCF, restLocalRot=restLocalRot,
                isFront=restLocalCF.Position.Z<0, axleAxis=axleAxis,
                radius=math.max((dims[2]+dims[3])/4, 0.3), spinAngle=0
            })
        end
    end

    local CAR_SPEED=75; local CAR_ACCEL=0.28; local CAR_BRAKE=0.18; local CAR_COAST=0.04
    local CAR_TURN=3.5; local CAR_TURN_LERP=0.22; local CAR_GRIP=0.88; local carTurnCurrent=0

    local function updateCarWheels(root, dt)
        if #carWheelData==0 then return end
        local vel=root.AssemblyLinearVelocity
        local speedXZ=Vector3.new(vel.X,0,vel.Z).Magnitude
        local direction=vel:Dot(root.CFrame.LookVector)>=0 and 1 or -1
        local steerAngle=(carTurnCurrent/CAR_TURN)*math.rad(30)
        for _, wd in pairs(carWheelData) do
            local w=wd.part
            if not w or not w.Parent or not partowner(w) then continue end
            wd.spinAngle=wd.spinAngle+(speedXZ/wd.radius)*dt*direction
            local spinCF
            if wd.axleAxis==0 then spinCF=CFrame.Angles(wd.spinAngle,0,0)
            elseif wd.axleAxis==1 then spinCF=CFrame.Angles(0,wd.spinAngle,0)
            else spinCF=CFrame.Angles(0,0,wd.spinAngle) end
            local steerCF=wd.isFront and CFrame.Angles(0,steerAngle,0) or CFrame.new()
            pcall(function()
                w.CFrame=root.CFrame*CFrame.new(wd.restLocalCF.Position)*steerCF*wd.restLocalRot*spinCF
            end)
        end
    end

    local function applyCarPhysics(root)
        if not partowner(root) or root.Anchored then return end
        local cf=root.CFrame
        local fwdFlat=Vector3.new(cf.LookVector.X,0,cf.LookVector.Z)
        local rightFlat=Vector3.new(cf.RightVector.X,0,cf.RightVector.Z)
        if fwdFlat.Magnitude>0.001 then fwdFlat=fwdFlat.Unit end
        if rightFlat.Magnitude>0.001 then rightFlat=rightFlat.Unit end
        local throttle=0
        if uis:IsKeyDown(Enum.KeyCode.W) then throttle=1 end
        if uis:IsKeyDown(Enum.KeyCode.S) then throttle=-1 end
        local curVel=root.AssemblyLinearVelocity
        local curXZ=Vector3.new(curVel.X,0,curVel.Z)
        local fwdSpeed=curXZ:Dot(fwdFlat); local latSpeed=curXZ:Dot(rightFlat)
        local newXZ=curXZ-rightFlat*latSpeed*CAR_GRIP
        if throttle~=0 then
            local targetFwd=throttle*CAR_SPEED; local diff=targetFwd-fwdSpeed
            local factor=(diff*throttle>0) and CAR_ACCEL or CAR_BRAKE
            newXZ=newXZ+fwdFlat*diff*factor
        else newXZ=newXZ*(1-CAR_COAST) end
        local speedFactor=math.min(curXZ.Magnitude/8,1)
        local steerDir=fwdSpeed>=0 and 1 or -1; local targetTurn=0
        if uis:IsKeyDown(Enum.KeyCode.A) then targetTurn=CAR_TURN*speedFactor*steerDir end
        if uis:IsKeyDown(Enum.KeyCode.D) then targetTurn=-CAR_TURN*speedFactor*steerDir end
        carTurnCurrent=carTurnCurrent+(targetTurn-carTurnCurrent)*CAR_TURN_LERP
        root.AssemblyLinearVelocity=Vector3.new(newXZ.X,curVel.Y,newXZ.Z)
        root.AssemblyAngularVelocity=Vector3.new(0,carTurnCurrent,0)
    end

