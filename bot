-- ✅ NEW: NPC Name Search Functionality
G["npcsearchbox"].FocusLost:Connect(function(enterPressed)
	if not enterPressed then return end
	-- ✅ FIXED: Using local trim() function instead of :trim() method to avoid readonly error
	local searchName = trim(G["npcsearchbox"].Text:lower())
	if searchName == "" then return end
	
	-- Search for NPC with fuzzy matching
	local foundNPC = nil
	local bestMatch = nil
	local bestScore = 0
	
	for _, desc in pairs(WS:GetDescendants()) do
		if desc:IsA("Model") then
			local hum = findHumanoid(desc)
			if hum and not PLRS:GetPlayerFromCharacter(desc) then
				local nameLower = desc.Name:lower()
				-- Exact match first
				if nameLower == searchName then
					foundNPC = desc
					break
				end
				-- Fuzzy match (contains)
				if nameLower:find(searchName, 1, true) then
					local score = searchName:len() / nameLower:len()
					if score > bestScore then
						bestScore = score
						bestMatch = desc
					end
				end
			end
		end
	end
	
	local selected = foundNPC or bestMatch
	if selected then
		-- Clear previous selection visuals
		if S.currentnpc and S.currentnpc ~= selected then addESP(S.currentnpc) end
		
		S.currentnpc = selected
		S.currentpart = nil
		removeESP(S.currentnpc)
		updateBotLabel(G["6"])
		
		-- Visual feedback
		flashSelect(selected, Color3.fromRGB(0, 255, 100))
		G["npcsearchbox"].Text = "✓ " .. selected.Name
		task.delay(2, function()
			if G["npcsearchbox"] and G["npcsearchbox"].Parent then
				G["npcsearchbox"].Text = ""
			end
		end)
		print("Selected NPC:", selected.Name)
	else
		G["npcsearchbox"].Text = "✗ Not found"
		task.delay(1.5, function()
			if G["npcsearchbox"] and G["npcsearchbox"].Parent then
				G["npcsearchbox"].Text = ""
			end
		end)
		print("NPC not found:", searchName)
	end
end)

