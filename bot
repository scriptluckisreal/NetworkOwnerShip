    -- orbit
    local orbitActive=false; local orbitCon=nil; local orbitObjects={}
    local ORBIT_RADIUS=45; local ORBIT_RESCAN=0.6

    local function collectOrbitTargets(center, excludeModel)
        local collected={}; local seen={}
        for _, part in pairs(ws:GetPartBoundsInRadius(center,ORBIT_RADIUS)) do
            if not part:IsA("BasePart") or part.Anchored then continue end
            local parentModel=part:FindFirstAncestorOfClass("Model")
            if parentModel then
                if plrs:GetPlayerFromCharacter(parentModel) or parentModel==excludeModel or seen[parentModel] then continue end
                local mp=getPrimaryPart(parentModel)
                if mp and not mp.Anchored then
                    seen[parentModel]=true
                    local off=mp.Position-center; local r=math.sqrt(off.X^2+off.Z^2)
                    table.insert(collected,{part=mp,angle=math.atan2(off.Z,off.X),
                        radius=math.clamp(r<4 and math.random(8,16) or r,6,40),
                        speed=math.random(90,200)/100,offsetY=math.random(-2,5)})
                end
            else
                if plrs:GetPlayerFromCharacter(part) or seen[part] then continue end
                if excludeModel and part:IsDescendantOf(excludeModel) then continue end
                if part.Anchored then continue end
                seen[part]=true
                local off=part.Position-center; local r=math.sqrt(off.X^2+off.Z^2)
                table.insert(collected,{part=part,angle=math.atan2(off.Z,off.X),
                    radius=math.clamp(r<4 and math.random(8,16) or r,6,40),
                    speed=math.random(90,200)/100,offsetY=math.random(-2,5)})
            end
        end
        return collected
    end

    local function mergeOrbitTargets(existing,newEntries)
        local seen={}; for _,od in pairs(existing) do seen[od.part]=true end
        for _,od in pairs(newEntries) do
            if not seen[od.part] then seen[od.part]=true; table.insert(existing,od) end
        end
    end

