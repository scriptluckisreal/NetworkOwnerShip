local function setupTouchFling()
    if S.touchFlingCon then S.touchFlingCon:Disconnect(); S.touchFlingCon = nil end
    if not S.touchFlingActive then return end
    local char = LP.Character; if not char then return end
    local function bindTouched(part)
        if not part:IsA("BasePart") then return end
        part.Touched:Connect(function(hit)
            if not S.touchFlingActive or not hit or not hit.Parent then return end
            if hit:IsDescendantOf(LP.Character or game) then return end
            local target = findNPCModel(hit)
            if not target then
                local m = findAnyModel(hit)
                if m and m ~= WS and not PLRS:GetPlayerFromCharacter(m) then target = m end
            end
            if not target or PLRS:GetPlayerFromCharacter(target) then return end
            serverFling(target)
        end)
    end
    for _, v in pairs(char:GetDescendants()) do bindTouched(v) end
    char.DescendantAdded:Connect(function(v) bindTouched(v) end)
end

