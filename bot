S.unanchoredCheckCon = RS.Heartbeat:Connect(function()
	if S.unanchoredHighlightActive then updateUnanchoredHighlights() end
	if S.highlightsActive then
		for model, h in pairs(S.espHighlights) do
			if model and model.Parent then
				local root = getRootPart(model)
