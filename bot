    if not target then return disabled end
    for _, p in pairs(getTargetParts(target)) do
        if (p:IsA("Seat") or p:IsA("VehicleSeat")) and not p.Disabled then
            pcall(function() p.Disabled = true; table.insert(disabled, p) end)
        end
    end
    return disabled
end

