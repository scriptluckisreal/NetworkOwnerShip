local function serverFling(target)
    if not target or not target.Parent then return end
    if PLRS:GetPlayerFromCharacter(target) then return end
    local rootp = getPrimaryPart(target)
    if not rootp or rootp.Anchored then return end
    task.spawn(function()
        setSimRadius(math.huge)
        for _ = 1, 8 do task.wait(); setSimRadius(math.huge); if partowner(rootp) then break end end
        if partowner(rootp) then
            for _, v in pairs(getTargetParts(target)) do
                pcall(function() if not v.Anchored then v.Anchored = false end end)
            end
            pcall(function()
                rootp.AssemblyLinearVelocity = Vector3.new(
                    math.random(-200,200), math.random(400,700), math.random(-200,200))
            end)
        end
    end)
end

local function findBestSeat(target)
