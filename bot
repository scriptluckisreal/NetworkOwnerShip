    local function waitForOwnership(part, timeout)
        if not part or part.Anchored then return false end
        local start = os.clock()
        while (os.clock() - start) < timeout do
            if part:GetNetworkOwner() == lp then return true end
            local age = 1; pcall(function() age = part.ReceiveAge end)
            if age == 0 then return true end
            task.wait(0.05)
        end
        return false
    end

