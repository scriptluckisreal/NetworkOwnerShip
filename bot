    local function restorePlayer(savedPos)
        safeStopControl()
        if not G2L["1"].Parent then G2L["1"].Parent=core end
        local isAlive=chr and chr.Parent~=nil; local newChar=lp.Character
        if isAlive then
            local chrHum=chr:FindFirstChildOfClass("Humanoid")
            if chrHum then pcall(function() chrHum.PlatformStand=false end) end
            setCollision(chr,true); zeroVelocity(chr)
            if savedPos then pcall(function() chr:PivotTo(savedPos) end) end
            lp.Character=chr
            local restoredChr=chr
            task.defer(function()
                if not G2L["1"].Parent then G2L["1"].Parent=core end
                local h=restoredChr:FindFirstChildOfClass("Humanoid")
                local hrp=restoredChr:FindFirstChild("HumanoidRootPart")
                ws.CurrentCamera.CameraSubject=h or hrp
                if h then h.PlatformStand=false; h:ChangeState(Enum.HumanoidStateType.Running) end
                zeroVelocity(restoredChr)
            end)
        else
            if newChar then
                lp.Character=newChar
                task.defer(function()
                    if not G2L["1"].Parent then G2L["1"].Parent=core end
                    ws.CurrentCamera.CameraSubject=
                        newChar:FindFirstChildOfClass("Humanoid") or newChar:FindFirstChild("HumanoidRootPart")
                    local nh=newChar:FindFirstChildOfClass("Humanoid")
                    if nh then nh.PlatformStand=false; nh:ChangeState(Enum.HumanoidStateType.Running) end
                    setCollision(newChar,true); zeroVelocity(newChar)
                end)
            end
        end
        if not G2L["1"].Parent then G2L["1"].Parent=core end
        chr=nil
    end

