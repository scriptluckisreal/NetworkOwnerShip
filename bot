-- ==================== DRIVE SYSTEM ====================
local function stopAllDrive(ridepart_btn, ghostdrive_btn, freedrive_btn, freefly_btn)
	local wasMode = S.driveMode; S.driveMode = nil
	if S.driveCon then S.driveCon:Disconnect(); S.driveCon = nil end
	if S.drivePhysicsCon then S.drivePhysicsCon:Disconnect(); S.drivePhysicsCon = nil end
	if ridepart_btn then ridepart_btn.Text = "Ride Part" end
	if ghostdrive_btn then ghostdrive_btn.Text = "Ghost Drive" end
	if freedrive_btn then freedrive_btn.Text = "Free Drive" end
	if freefly_btn then freefly_btn.Text = "Free Fly" end
	for _, v in pairs(S.driveDisabledSeats) do pcall(function() v.Disabled = false end) end
	S.driveDisabledSeats = {}; S.carTurnCurrent = 0; S.carWheelData = {}
	if not S.controlActive then setSimRadius(S.rad) end

	if wasMode == "ghost" and S.driveChr then
		local restChr = S.driveChr; S.driveChr = nil
		local t = S.currentpart or S.currentnpc; local destCF = nil
		if t and t.Parent then
			local seat = findBestSeat(t)
			if seat then destCF = CFrame.new(seat.Position + Vector3.new(0, seat.Size.Y * 0.5 + 3.5, 0))
			else local r = getPrimaryPart(t); if r then destCF = CFrame.new(r.Position + Vector3.new(0, r.Size.Y * 0.5 + 3.5, 0)) end end
		end
		local rh = restChr and restChr:FindFirstChildOfClass("Humanoid")
		if rh then rh.PlatformStand = false end
		setCollision(restChr, true); zeroVelocity(restChr)
		if destCF then
			local rchrp = restChr and restChr:FindFirstChild("HumanoidRootPart")
			if rchrp then
				pcall(function() rchrp.CFrame = destCF end)
			else
				pcall(function() restChr:PivotTo(destCF) end)
			end
		end
		LP.Character = restChr
		task.defer(function()
			local h2 = restChr and restChr:FindFirstChildOfClass("Humanoid")
			local hrp = restChr and restChr:FindFirstChild("HumanoidRootPart")
			WS.CurrentCamera.CameraSubject = h2 or hrp
			if h2 then h2.PlatformStand = false; h2:ChangeState(Enum.HumanoidStateType.Running) end
			zeroVelocity(restChr)
		end)
	elseif wasMode == "free" then
		local c = LP.Character; local h = c and c:FindFirstChildOfClass("Humanoid")
		if h then h.WalkSpeed = S.freeDriveOrigWS end; restorePlayerCamera()
	elseif wasMode == "ride" then
		local c = LP.Character; local h = c and c:FindFirstChildOfClass("Humanoid")
		if h then h.PlatformStand = false; h:ChangeState(Enum.HumanoidStateType.Running) end
		setCollision(c, true)
		restorePlayerCamera()
	elseif wasMode == "fly" then
		S.flyLoopActive = false; if S.flyBV then pcall(function() S.flyBV:Destroy() end); S.flyBV = nil end
		local c = LP.Character; local h = c and c:FindFirstChildOfClass("Humanoid")
		if h then pcall(function() h.WalkSpeed = S.flyOrigWS end) end
		restorePlayerCamera()
	end
end

local function startDrive(mode, target, ridepart_btn, ghostdrive_btn, freedrive_btn, freefly_btn)
	if S.driveMode ~= nil then stopAllDrive(ridepart_btn, ghostdrive_btn, freedrive_btn, freefly_btn) end
	if not target then return end
	local root = getPrimaryPart(target)
	if not root or root.Anchored then return end
	if mode ~= "free" and mode ~= "fly" then S.driveDisabledSeats = disableTargetSeats(target) else S.driveDisabledSeats = {} end
	S.driveMode = mode
	S.carTurnCurrent = 0
	task.defer(function() detectCarWheels(target, root) end)

	-- ✅ IMPROVED: Network ownership claim with faster retries
	task.spawn(function()
		for i = 1, 80 do
			if S.driveMode ~= mode then break end
			setSimRadius(math.huge)
			pcall(function()
				if root and root.Parent and not root.Anchored then
					root:SetNetworkOwner(LP)
				end
			end)
			if partowner(root) then break end
			task.wait(0.05)
		end
	end)

	if mode == "ride" and ridepart_btn then ridepart_btn.Text = "✓ Ride Part"
	elseif mode == "ghost" and ghostdrive_btn then ghostdrive_btn.Text = "✓ Ghost Drive"
	elseif mode == "free" and freedrive_btn then freedrive_btn.Text = "✓ Free Drive"
	elseif mode == "fly" and freefly_btn then freefly_btn.Text = "✓ Free Fly" end

	local c = LP.Character
	local h = c and c:FindFirstChildOfClass("Humanoid")

	local function enforceCam(subject)
		pcall(function() WS.CurrentCamera.CameraSubject = subject end)
		task.defer(function() pcall(function() WS.CurrentCamera.CameraSubject = subject end) end)
		task.delay(0.1, function() pcall(function() WS.CurrentCamera.CameraSubject = subject end) end)
		task.delay(0.3, function() pcall(function() WS.CurrentCamera.CameraSubject = subject end) end)
	end

	if mode == "ride" then
		if h then h.PlatformStand = true end
		setCollision(c, false)
		enforceCam(root)
	elseif mode == "ghost" then
		S.driveChr = c
		if c then setCollision(c, false) end
		if h then h.PlatformStand = true end
		enforceCam(root)
	elseif mode == "free" then
		S.freeDriveOrigWS = (h and h.WalkSpeed) or 16
		if h then h.WalkSpeed = 0 end
		enforceCam(root)
	elseif mode == "fly" then
		S.flyOrigWS = (h and h.WalkSpeed) or 16
		if h then pcall(function() h.WalkSpeed = 0 end) end
		deepUnanchor(target)
		S.flyLoopActive = true
		target.AncestryChanged:Connect(function()
			if S.driveMode == "fly" and not target.Parent then
				stopAllDrive(ridepart_btn, ghostdrive_btn, freedrive_btn, freefly_btn)
			end
		end)
		task.spawn(function()
			while S.flyLoopActive and S.driveMode == "fly" do
				local t2 = S.currentpart or S.currentnpc
				if not t2 or not t2.Parent then stopAllDrive(ridepart_btn, ghostdrive_btn, freedrive_btn, freefly_btn); break end
				local cam = WS.CurrentCamera
				local camCF = cam.CFrame
				local look = camCF.LookVector
				local right = camCF.RightVector
				local r2 = getPrimaryPart(t2)
				if r2 and partowner(r2) and not r2.Anchored and look.Magnitude > 0.001 then
					local newCF = CFrame.new(r2.Position, r2.Position + look)
					pcall(function() if t2:IsA("Model") then t2:PivotTo(newCF) else r2.CFrame = newCF end end)
				end
				local dir = Vector3.zero
				if UIS:IsKeyDown(Enum.KeyCode.W) then dir = dir + look end
				if UIS:IsKeyDown(Enum.KeyCode.S) then dir = dir - look end
				if UIS:IsKeyDown(Enum.KeyCode.A) then dir = dir - right end
				if UIS:IsKeyDown(Enum.KeyCode.D) then dir = dir + right end
				if UIS:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
				if UIS:IsKeyDown(Enum.KeyCode.LeftShift) or UIS:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.new(0, 1, 0) end
				if dir.Magnitude > 0.001 then
					pcall(function() if S.flyBV then S.flyBV.Velocity = dir.Unit * S.CAR_SPEED end end)
				else
					pcall(function() if S.flyBV then S.flyBV.Velocity = Vector3.new(0, 0.1, 0) end end)
				end
				task.wait()
			end
			if S.flyBV then pcall(function() S.flyBV:Destroy() end); S.flyBV = nil end
		end)
		enforceCam(root)
	end

	S.driveCon = RS.Heartbeat:Connect(function()
		if not S.driveMode then return end
		local t = S.currentpart or S.currentnpc
		if not t or not t.Parent then stopAllDrive(ridepart_btn, ghostdrive_btn, freedrive_btn, freefly_btn); return end
		local r = getPrimaryPart(t)
		if not r then stopAllDrive(ridepart_btn, ghostdrive_btn, freedrive_btn, freefly_btn); return end
		if r.Anchored then stopAllDrive(ridepart_btn, ghostdrive_btn, freedrive_btn, freefly_btn); return end

		setSimRadius(math.huge)
		pcall(function() r:SetNetworkOwner(LP) end)

		if S.driveMode ~= "fly" then
			pcall(function() if WS.CurrentCamera.CameraSubject ~= r then WS.CurrentCamera.CameraSubject = r end end)
		end

		if S.driveMode == "ride" then
			local pc = LP.Character
			local ph = pc and pc:FindFirstChildOfClass("Humanoid")
			local rhrp = pc and pc:FindFirstChild("HumanoidRootPart")
			if rhrp then
				pcall(function()
					rhrp.CFrame = r.CFrame * CFrame.new(0, r.Size.Y * 0.5 + 3.5, 0)
					rhrp.AssemblyLinearVelocity = Vector3.zero
					rhrp.AssemblyAngularVelocity = Vector3.zero
				end)
			end
			if ph and not ph.PlatformStand then ph.PlatformStand = true end

		elseif S.driveMode == "ghost" then
			local dc = S.driveChr
			if not dc or not dc.Parent then stopAllDrive(ridepart_btn, ghostdrive_btn, freedrive_btn, freefly_btn); return end
			local dchrp = dc:FindFirstChild("HumanoidRootPart")
			if dchrp then
				pcall(function()
					dchrp.CFrame = CFrame.new(0, -10000, 0)
					dchrp.AssemblyLinearVelocity = Vector3.zero
					dchrp.AssemblyAngularVelocity = Vector3.zero
				end)
			end
			local dh = dc:FindFirstChildOfClass("Humanoid")
			if dh and not dh.PlatformStand then dh.PlatformStand = true end

		elseif S.driveMode == "free" then
			local pc = LP.Character
			local ph = pc and pc:FindFirstChildOfClass("Humanoid")
			if ph and ph.WalkSpeed ~= 0 then ph.WalkSpeed = 0 end

		elseif S.driveMode == "fly" then
			local pc = LP.Character
			local ph = pc and pc:FindFirstChildOfClass("Humanoid")
			if ph and ph.WalkSpeed ~= 0 then pcall(function() ph.WalkSpeed = 0 end) end
		end
	end)

	S.drivePhysicsCon = RS.PreSimulation:Connect(function(dt)
		if not S.driveMode then
			if S.drivePhysicsCon then S.drivePhysicsCon:Disconnect(); S.drivePhysicsCon = nil end
			return
		end
		local t = S.currentpart or S.currentnpc
		if not t or not t.Parent then return end
		local r = getPrimaryPart(t)
		if not r or r.Anchored then return end

		setSimRadius(math.huge)
		pcall(function() r:SetNetworkOwner(LP) end)

		if not partowner(r) then return end

		if S.driveMode ~= "fly" then
			applyCarPhysics(r)
			updateCarWheels(r, dt)
		end
	end)
end

local function restorePlayer(savedPos, controlbtn)
	if S.deathcon then S.deathcon:Disconnect(); S.deathcon = nil end
	if S.cons then S.cons:Disconnect(); S.cons = nil end
	if S.tpcon then S.tpcon:Disconnect(); S.tpcon = nil end
	S.npcMissingCount = 0
	local isAlive = S.chr and S.chr.Parent ~= nil; local newChar = LP.Character
	if isAlive then
		local chrHum = S.chr:FindFirstChildOfClass("Humanoid")
		if chrHum then pcall(function() chrHum.PlatformStand = false end) end
		setCollision(S.chr, true); zeroVelocity(S.chr)
		if savedPos then
			local resthrp = S.chr:FindFirstChild("HumanoidRootPart")
			if resthrp then
				pcall(function() resthrp.CFrame = savedPos end)
			else
				pcall(function() S.chr:PivotTo(savedPos) end)
			end
		end
		LP.Character = S.chr
		local restoredChr = S.chr
		task.defer(function()
			local h = restoredChr:FindFirstChildOfClass("Humanoid")
			local hrp = restoredChr:FindFirstChild("HumanoidRootPart")
			WS.CurrentCamera.CameraSubject = h or hrp
			if h then h.PlatformStand = false; h:ChangeState(Enum.HumanoidStateType.Running) end
			zeroVelocity(restoredChr)
		end)
	else
		if newChar then
			LP.Character = newChar
			task.defer(function()
				WS.CurrentCamera.CameraSubject = newChar:FindFirstChildOfClass("Humanoid") or newChar:FindFirstChild("HumanoidRootPart")
				local nh = newChar:FindFirstChildOfClass("Humanoid")
				if nh then nh.PlatformStand = false; nh:ChangeState(Enum.HumanoidStateType.Running) end
				setCollision(newChar, true); zeroVelocity(newChar)
			end)
		end
	end
	if controlbtn then S.controlActive = false; controlbtn.Text = "Control Bot" end
	S.chr = nil
end

-- ==================== CHAT COMMAND SYSTEM ====================
local function findNPCByName(name)
	local searchName = name:lower()
	for _, desc in pairs(WS:GetDescendants()) do
		if desc:IsA("Model") and desc.Name:lower():find(searchName) then
			if findHumanoid(desc) and not PLRS:GetPlayerFromCharacter(desc) then
				return desc
			end
		end
	end
	return nil
end

local function executeChatCommand(msg)
	local cmd = msg:lower()

	-- !bring [npcname]
	if cmd:sub(1, 6) == "!bring" or cmd:sub(1, 6) == ":bring" then
		local npcName = msg:sub(8)
		if npcName and npcName ~= "" then
			local npc = findNPCByName(npcName)
			if npc then
				S.currentnpc = npc
				S.currentpart = nil
				-- Bring NPC
				local target = npc
				task.spawn(function()
					local part = getPrimaryPart(target)
					if not part or part.Anchored then return end
					setSimRadius(math.huge)
					pcall(function() part:SetNetworkOwner(LP) end)
					for _ = 1, 15 do task.wait(0.05); setSimRadius(math.huge); pcall(function() part:SetNetworkOwner(LP) end); if partowner(part) then break end end
					local char = LP.Character; if not char then return end
					local charHRP = char:FindFirstChild("HumanoidRootPart"); if not charHRP then return end
					local destCF = charHRP.CFrame * CFrame.new(0, 0, -5)
					for _, v in pairs(getTargetParts(target)) do pcall(function() v.Anchored = false end) end
					pivotTarget(target, destCF)
					for _, v in pairs(getTargetParts(target)) do
						pcall(function()
							v.AssemblyLinearVelocity = Vector3.zero
							v.AssemblyAngularVelocity = Vector3.zero
						end)
					end
				end)
				print("Brought NPC:", npc.Name)
			else
				print("NPC not found:", npcName)
			end
		end

	-- :freeze
	elseif cmd == ":freeze" or cmd == "!freeze" then
		if S.currentnpc or S.currentpart then
			S.freezeActive = true
			S.freezeOrigAnchored = {}
			local target = getActiveTarget()
			if target and target.Parent then
				for _, v in pairs(getTargetParts(target)) do S.freezeOrigAnchored[v] = v.Anchored end
			end
			if S.freezecon then S.freezecon:Disconnect() end
			S.freezecon = RS.Heartbeat:Connect(function()
				local t = getActiveTarget(); if not t or not t.Parent then return end
				setSimRadius(math.huge)
				for _, v in pairs(getTargetParts(t)) do
					pcall(function() v.Anchored = true; v.AssemblyLinearVelocity = Vector3.zero; v.AssemblyAngularVelocity = Vector3.zero end)
				end
			end)
			print("Frozen!")
		end

	-- :unfreeze
	elseif cmd == ":unfreeze" or cmd == "!unfreeze" then
		S.freezeActive = false
		if S.freezecon then S.freezecon:Disconnect(); S.freezecon = nil end
		local target = getActiveTarget()
		if target and target.Parent then
			for _, v in pairs(getTargetParts(target)) do
				local origAnchored = S.freezeOrigAnchored[v]
				if origAnchored ~= nil then pcall(function() v.Anchored = origAnchored end) end
			end
		end
		S.freezeOrigAnchored = {}
		print("Unfrozen!")

	-- :control
	elseif cmd == ":control" or cmd == "!control" then
		if S.currentnpc then
			local capturedNPC = S.currentnpc
			setSimRadius(math.huge)
			local part = getRootPart(capturedNPC)
			if part and not part.Anchored then
				deepUnanchor(capturedNPC); S.disabledScripts = deepDisableScripts(capturedNPC)
				prepNPCHumanoid(capturedNPC)
				if LP and LP.Character then
					S.chr = LP.Character
					local chrhrp = S.chr:FindFirstChild("HumanoidRootPart")
					S.savedPosition = chrhrp and chrhrp.CFrame or nil
					setCollision(S.chr, false)
					local chrHum = S.chr:FindFirstChildOfClass("Humanoid")
					if chrHum then chrHum.PlatformStand = true end
					LP.Character = capturedNPC
					WS.CurrentCamera.CameraSubject = getCameraSubject(capturedNPC)
					S.controlActive = true
					print("Controlling NPC!")
				end
			end
		end

	-- :uncontrol
	elseif cmd == ":uncontrol" or cmd == "!uncontrol" then
		if S.controlActive then
			local sp = S.savedPosition; S.savedPosition = nil
			restorePlayer(sp, nil)
			S.controlActive = false
			print("Control stopped!")
		end

	-- :view
	elseif cmd == ":view" or cmd == "!view" then
		if S.currentnpc then
			local subject = getCameraSubject(S.currentnpc)
			if subject then WS.CurrentCamera.CameraSubject = subject end
			print("Viewing NPC!")
		end

	-- :unview
	elseif cmd == ":unview" or cmd == "!unview" then
		local char = LP.Character
		if char then WS.CurrentCamera.CameraSubject = char:FindFirstChildOfClass("Humanoid") or char:FindFirstChild("HumanoidRootPart") end
		print("Stopped viewing!")

	-- :kill
	elseif cmd == ":kill" or cmd == "!kill" then
		if S.currentnpc then
			local part = getRootPart(S.currentnpc)
			if part and not part.Anchored and partowner(part) then
				local hum = findHumanoid(S.currentnpc)
				if hum then hum:ChangeState(Enum.HumanoidStateType.Dead) end
			end
			print("Killed NPC!")
		end

	-- :fling
	elseif cmd == ":fling" or cmd == "!fling" then
		local target = getActiveTarget()
		if target then
			serverFling(target)
			print("Flinged!")
		end
	end
end

