                        if S.npcMissingCount >= 60 then
                            local sp = S.savedPosition; S.savedPosition = nil
                            S.controlActive = false; G["3"].Text = "Control Bot"
                            for _, v in pairs(S.disabledScripts) do pcall(function() v.Enabled = true end) end
                            S.disabledScripts = {}; restorePlayer(sp, G["3"])
