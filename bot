                npcFreeActive = false; return
            end
            
            -- Prep NPC
            hum.PlatformStand = true
            hum.AutoRotate = false
            deepUnanchor(currentnpc)
            
            -- Claim ownership
            if not waitForOwnership(root, 2) then
                npcFreeActive = false; return
            end
            setNetworkOwner(root)
            
            -- Control loop
            npcFreeCon = rs.Heartbeat:Connect(function()
                if not npcFreeActive or not currentnpc or not currentnpc.Parent then
                    if npcFreeCon then npcFreeCon:Disconnect(); npcFreeCon = nil end
                    return
                end
                
                local r = getRootPart(currentnpc)
                local h = findHumanoid(currentnpc)
                if not r or not h or r.Anchored then return end
                
                -- Re-assert ownership
                if r:GetNetworkOwner() ~= lp then
                    if waitForOwnership(r, 0.3) then setNetworkOwner(r)
                    else npcFreeActive = false; return end
                end
                
                -- Camera-based movement
                local cam = ws.CurrentCamera
                local camCF = cam.CFrame
                local look = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z).Unit
                local right = Vector3.new(camCF.RightVector.X, 0, camCF.RightVector.Z).Unit
                
                local moveDir = Vector3.zero
                if uis:IsKeyDown(Enum.KeyCode.W) then moveDir += look end
                if uis:IsKeyDown(Enum.KeyCode.S) then moveDir -= look end
                if uis:IsKeyDown(Enum.KeyCode.A) then moveDir -= right end
                if uis:IsKeyDown(Enum.KeyCode.D) then moveDir += right end
                
                if moveDir.Magnitude > 0.1 then
                    moveDir = moveDir.Unit
                    h.MoveDirection = moveDir
                    h.WalkSpeed = 35
                    -- Fallback velocity
                    if math.abs(r.AssemblyLinearVelocity:Dot(moveDir)) < 5 then
                        safePhysics(r, moveDir * 35 + Vector3.new(0, r.AssemblyLinearVelocity.Y, 0))
                        r.CFrame = CFrame.new(r.Position, r.Position + moveDir)
                    end
                else
                    h.MoveDirection = Vector3.zero
                    safePhysics(r, Vector3.new(0, r.AssemblyLinearVelocity.Y, 0))
                end
                
                -- Jump
                if uis:IsKeyDown(Enum.KeyCode.Space) and h.FloorMaterial ~= Enum.Material.Air then
                    h.Jump = true
                end
            end)
